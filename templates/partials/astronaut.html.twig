<div class="bg-white dark:bg-gray-900 border border-slate-200 dark:border-gray-800/80 rounded-2xl overflow-hidden shadow-md hover:shadow-xl hover:border-indigo-500/30 dark:hover:border-indigo-400/30 transition-all duration-300 flex flex-col h-full group">
    <!-- Image Header with gradient overlay -->
    <div class="relative aspect-[4/5] w-full overflow-hidden bg-slate-950">
        <img src="{{ astronaut.profileImg }}" 
             alt="{{ astronaut.name }}" 
             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
        
        <!-- Status Indicator Badge -->
        <div class="absolute top-3 right-3 z-10">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider {% if astronaut.status == 'Active' %} bg-emerald-500/90 text-white {% else %} bg-slate-500/90 text-white {% endif %} shadow-sm">
                {{ astronaut.status }}
            </span>
        </div>
        
        <!-- Role overlay at the bottom -->
        {% if astronaut.role %}
            <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-slate-950 via-slate-950/40 to-transparent p-4 pt-12 z-10">
                <span class="text-[10px] font-bold text-indigo-300 dark:text-indigo-400 uppercase tracking-widest block">
                    {{ astronaut.role }}
                </span>
            </div>
        {% endif %}
    </div>

    <!-- Content Details -->
    <div class="p-4 flex-grow flex flex-col justify-between space-y-4 text-slate-800 dark:text-gray-100">
        <div>
            <h4 class="text-base font-bold text-slate-900 dark:text-white group-hover:text-indigo-650 dark:group-hover:text-indigo-400 transition-colors line-clamp-1">
                {{ astronaut.name }}
            </h4>
            <span class="text-xs text-slate-500 dark:text-gray-400 mt-1 block">
                <i class="fas fa-flag mr-1 text-xs opacity-70"></i>{{ astronaut.nationality }}
            </span>
        </div>

        <div class="space-y-3">
            <hr class="border-slate-100 dark:border-gray-800/80">
            
            <!-- Quick Actions -->
            <div class="flex items-center justify-between gap-2">
                <div class="flex items-center space-x-2">
                    {% if astronaut.twitter %}
                        <a href="{{ astronaut.twitter }}" target="_blank" rel="noopener" class="text-slate-400 hover:text-[#1DA1F2] transition-colors" title="Twitter">
                            <i class="fab fa-twitter text-sm"></i>
                        </a>
                    {% endif %}
                    {% if astronaut.instagram %}
                        <a href="{{ astronaut.instagram }}" target="_blank" rel="noopener" class="text-slate-400 hover:text-[#E1306C] transition-colors" title="Instagram">
                            <i class="fab fa-instagram text-sm"></i>
                        </a>
                    {% endif %}
                    {% if astronaut.wiki %}
                        <a href="{{ astronaut.wiki }}" target="_blank" rel="noopener" class="text-slate-400 hover:text-slate-650 dark:hover:text-white transition-colors" title="Wikipedia">
                            <i class="fab fa-wikipedia-w text-xs"></i>
                        </a>
                    {% endif %}
                </div>
                
                <div class="flex items-center space-x-1.5">
                    <a href="{{ path('agency', {'nameSlug' : astronaut.agency.name | slug | lower, 'idApi': astronaut.agency.idApi }) }}" 
                       class="text-[10px] font-bold px-2 py-1 rounded bg-slate-50 dark:bg-gray-800 text-slate-600 dark:text-gray-300 hover:bg-indigo-50 dark:hover:bg-indigo-950/40 hover:text-indigo-650 dark:hover:text-indigo-400 transition-all border border-slate-200/50 dark:border-gray-700/50" 
                       title="{{ astronaut.agency.name }}">
                        Agency
                    </a>
                    <a href="{{ path('astronaut', {'nameAstro' : astronaut.name | slug | lower ,'idApi': astronaut.idApi}) }}" 
                       class="text-[10px] font-bold px-2 py-1 rounded bg-indigo-650 hover:bg-indigo-500 text-white transition-all shadow-sm">
                        Bio
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>