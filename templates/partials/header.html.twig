{% set route_name = app.request.attributes.get('_route') %}
<header class="w-full bg-white/80 dark:bg-gray-950/80 backdrop-blur-md border-b border-slate-250 dark:border-gray-800/60 sticky top-0 z-50 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <!-- Brand / Logo -->
            <div class="flex items-center">
                <a class="flex items-center space-x-3 group" href="{{ path('home') }}">
                    <div class="relative bg-indigo-500/10 dark:bg-indigo-500/20 p-2 rounded-lg border border-indigo-500/20 dark:border-indigo-500/30 group-hover:bg-indigo-500/20 dark:group-hover:bg-indigo-500/30 transition-all duration-300">
                        <img src="{{ asset('images/international-space-station-ico.png') }}" 
                             alt="ISS Logo" 
                             class="h-6 w-6 object-contain filter dark:brightness-110 group-hover:scale-110 transition-transform duration-300">
                    </div>
                    <span class="text-xl font-bold tracking-tight text-slate-900 dark:text-white group-hover:text-indigo-650 dark:group-hover:text-indigo-400 transition-colors">
                        SeeISS
                    </span>
                </a>
            </div>

            <!-- Navigation Menu -->
            <nav class="hidden md:flex items-center bg-slate-100/80 dark:bg-gray-900/60 p-1 rounded-xl border border-slate-200/80 dark:border-gray-800/80 space-x-1">
                <a class="text-sm font-semibold px-4 py-1.5 rounded-lg transition-all duration-200 flex items-center {% if route_name == "live" %} bg-white dark:bg-gray-950 text-indigo-600 dark:text-indigo-400 shadow-sm border border-slate-200/50 dark:border-gray-850 {% else %} border border-transparent text-slate-650 hover:text-slate-900 dark:text-gray-300 dark:hover:text-white {% endif %}"
                   href="{{ path('live') }}">
                    <i class="fas fa-satellite-dish mr-1.5 text-xs"></i> {% trans %}realtime{% endtrans %}
                </a>
                
                <!-- Wiki Dropdown Group -->
                <div class="relative group">
                    <button class="text-sm font-semibold px-4 py-1.5 rounded-lg transition-all duration-200 flex items-center cursor-pointer {% if route_name in ['spacestation', 'agency', 'astronaut', 'launch'] %} bg-white dark:bg-gray-950 text-indigo-650 dark:text-indigo-400 shadow-sm border border-slate-200/50 dark:border-gray-850 {% else %} border border-transparent text-slate-650 hover:text-slate-900 dark:text-gray-300 dark:hover:text-white {% endif %}">
                        <i class="fas fa-book-open mr-1.5 text-xs"></i> {{ 'spaceWiki'|trans }}
                        <i class="fas fa-chevron-down ml-1.5 text-[10px] opacity-60 group-hover:rotate-180 transition-transform duration-200"></i>
                    </button>
                    
                    <!-- Dropdown Mega Menu -->
                    <div class="absolute left-1/2 -translate-x-1/2 mt-2 w-[480px] bg-white/95 dark:bg-slate-900/95 backdrop-blur-md border border-slate-200/70 dark:border-gray-800/80 rounded-2xl shadow-xl py-5 px-6 opacity-0 translate-y-2 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto transition-all duration-250 z-50 grid grid-cols-2 gap-6">
                        <!-- Space Stations & Agencies -->
                        <div class="space-y-4">
                            <div>
                                <h4 class="text-[10px] font-bold text-slate-400 dark:text-gray-500 uppercase tracking-wider mb-2 flex items-center">
                                    <i class="fas fa-satellite mr-1.5"></i> Space Stations
                                </h4>
                                <ul class="space-y-1.5">
                                    {% for station in get_wiki_spacestations() %}
                                        <li>
                                            <a href="{{ path('spacestation', {'idApi': station.idApi}) }}" 
                                               class="text-xs font-semibold text-slate-700 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400 flex items-center transition-colors">
                                                <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 mr-2 shrink-0"></span>
                                                {{ station.name }}
                                            </a>
                                        </li>
                                    {% endfor %}
                                </ul>
                            </div>
                            
                            <div class="pt-1">
                                <h4 class="text-[10px] font-bold text-slate-400 dark:text-gray-500 uppercase tracking-wider mb-2 flex items-center">
                                    <i class="fas fa-building mr-1.5"></i> Space Agencies
                                </h4>
                                <ul class="space-y-1.5 max-h-40 overflow-y-auto pr-1">
                                    {% for agency in get_wiki_agencies() %}
                                        <li>
                                            <a href="{{ path('agency', {'nameSlug': agency.name | slug | lower, 'idApi': agency.idApi}) }}" 
                                               class="text-xs font-semibold text-slate-700 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400 flex items-center transition-colors">
                                                <span class="w-1.5 h-1.5 rounded-full bg-slate-350 dark:bg-gray-700 mr-2 shrink-0"></span>
                                                {{ agency.name }}
                                            </a>
                                        </li>
                                    {% endfor %}
                                </ul>
                            </div>
                        </div>
                        
                        <!-- Astronauts & Launches -->
                        <div class="space-y-4">
                            <div>
                                <h4 class="text-[10px] font-bold text-slate-400 dark:text-gray-500 uppercase tracking-wider mb-2 flex items-center">
                                    <i class="fas fa-user-astronaut mr-1.5"></i> Active Astronauts
                                </h4>
                                <ul class="space-y-1.5 max-h-40 overflow-y-auto pr-1">
                                    {% for astronaut in get_wiki_astronauts() %}
                                        <li>
                                            <a href="{{ path('astronaut', {'nameAstro': astronaut.name | slug | lower, 'idApi': astronaut.idApi}) }}" 
                                               class="text-xs font-semibold text-slate-700 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400 flex items-center transition-colors">
                                                <span class="w-1.5 h-1.5 rounded-full bg-slate-350 dark:bg-gray-700 mr-2 shrink-0"></span>
                                                {{ astronaut.name }}
                                            </a>
                                        </li>
                                    {% endfor %}
                                </ul>
                            </div>
                            
                            <div>
                                <h4 class="text-[10px] font-bold text-slate-400 dark:text-gray-500 uppercase tracking-wider mb-2 flex items-center">
                                    <i class="fas fa-rocket mr-1.5"></i> Recent Launches
                                </h4>
                                <ul class="space-y-1.5 max-h-40 overflow-y-auto pr-1">
                                    {% for launch in get_wiki_launches() %}
                                        <li>
                                            <a href="{{ path('launch', {'slug': launch.slug, 'idApi': launch.idApi}) }}" 
                                               class="text-xs font-semibold text-slate-700 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400 flex items-center transition-colors"
                                               title="{{ launch.name }}">
                                                <span class="w-1.5 h-1.5 rounded-full bg-slate-350 dark:bg-gray-700 mr-2 shrink-0"></span>
                                                <span class="truncate">{{ launch.name }}</span>
                                            </a>
                                        </li>
                                    {% endfor %}
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </nav>

            <!-- Language selector, Theme switcher & Mobile toggle -->
            <div class="flex items-center space-x-3">
                <!-- Theme Toggle Sliding Switch -->
                <button id="theme-toggle" type="button" role="switch" aria-checked="false"
                        class="relative inline-flex h-8 w-14 shrink-0 cursor-pointer items-center rounded-full bg-slate-200/80 hover:bg-slate-300/80 dark:bg-gray-800/70 dark:hover:bg-gray-700/80 border border-slate-300/40 dark:border-gray-700/60 transition-all duration-300 focus:outline-none"
                        title="Toggle theme">
                    <span class="sr-only">Toggle theme</span>
                    <!-- Background Sun Icon -->
                    <span class="absolute left-2.5 text-slate-400/80 dark:text-gray-600 text-[10px] pointer-events-none flex items-center justify-center">
                        <i class="fas fa-sun"></i>
                    </span>
                    <!-- Background Moon Icon -->
                    <span class="absolute right-2.5 text-slate-300 dark:text-indigo-400/80 text-[10px] pointer-events-none flex items-center justify-center">
                        <i class="fas fa-moon"></i>
                    </span>
                    <!-- Knob -->
                    <span class="absolute left-1 dark:left-7 pointer-events-none block h-6 w-6 rounded-full bg-white dark:bg-slate-900 shadow-md transition-[left] duration-300 ease-in-out flex items-center justify-center z-10">
                        <i class="fas fa-sun text-[10px] text-amber-500 absolute transition-opacity duration-300 dark:opacity-0"></i>
                        <i class="fas fa-moon text-[10px] text-indigo-400 absolute transition-opacity duration-300 opacity-0 dark:opacity-100"></i>
                    </span>
                </button>

                <!-- Page Share Button -->
                <button id="page-share-btn" type="button"
                        class="bg-slate-100 hover:bg-slate-200 dark:bg-gray-900/60 dark:hover:bg-gray-800/80 border border-slate-200 dark:border-gray-800 text-slate-650 dark:text-gray-400 p-2.5 rounded-lg text-sm transition-all focus:outline-none cursor-pointer"
                        title="Share this page">
                    <i class="fas fa-share-alt text-sm"></i>
                </button>

                {% if app.request.attributes.get('_route') is not null %}
                    <div class="relative">
                        {% set url = path(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')) %}
                        
                        <button id="language-selector-btn" class="flex items-center space-x-2 bg-slate-100 hover:bg-slate-200 border border-slate-200 dark:bg-gray-900/60 dark:hover:bg-gray-800/80 dark:border-gray-800 px-3 py-1.5 rounded-lg text-sm text-slate-800 dark:text-gray-300 transition-all focus:outline-none">
                            {% if app.request.locale == "fr" %}
                                <span>🇫🇷</span> <span class="hidden sm:inline">Français</span>
                            {% else %}
                                <span>🇺🇸</span> <span class="hidden sm:inline">English</span>
                            {% endif %}
                            <i class="fas fa-chevron-down text-xs opacity-60"></i>
                        </button>
                        
                        <!-- Dropdown list (Click based) -->
                        <div id="language-selector-dropdown" class="absolute right-0 mt-2 w-40 bg-white dark:bg-gray-900 border border-slate-200 dark:border-gray-800 rounded-lg shadow-xl py-1 opacity-0 pointer-events-none transition-all duration-200 z-50 text-slate-800 dark:text-gray-300">
                            {% if app.request.locale == 'fr' %}
                                <a class="flex items-center space-x-3 px-4 py-2 text-sm hover:bg-slate-100 dark:hover:bg-indigo-600 dark:hover:text-white transition-all" 
                                   href="{{ path('language_selector', {'lang' : 'en', 'lastUrl' : url}) }}">
                                    <span>🇺🇸</span> <span>English</span>
                                </a>
                            {% else %}
                                <a class="flex items-center space-x-3 px-4 py-2 text-sm hover:bg-slate-100 dark:hover:bg-indigo-600 dark:hover:text-white transition-all" 
                                   href="{{ path('language_selector', {'lang' : 'fr', 'lastUrl' : url}) }}">
                                    <span>🇫🇷</span> <span>Français</span>
                                </a>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}

                <!-- Mobile Menu Button -->
                <button id="mobile-menu-toggle" class="md:hidden p-2 rounded-lg bg-slate-100 hover:bg-slate-200 border border-slate-200 dark:bg-gray-900/60 dark:border-gray-800 text-slate-600 dark:text-gray-400 dark:hover:text-white dark:hover:bg-gray-800/80 transition-all">
                    <i class="fas fa-bars text-lg"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile Navigation Drawer -->
    <div id="mobile-menu" class="hidden md:hidden bg-slate-50 dark:bg-gray-950 border-t border-slate-200 dark:border-gray-900 px-4 py-4 space-y-2 transition-all duration-300">
        <a class="flex items-center px-4 py-3 rounded-xl text-sm font-semibold transition-all {% if route_name == "live" %} bg-white dark:bg-gray-900 text-indigo-600 dark:text-indigo-400 shadow-sm border border-slate-200 dark:border-gray-800 {% else %} border border-transparent text-slate-650 hover:bg-slate-100/50 dark:text-gray-300 dark:hover:bg-gray-900/45 {% endif %}"
           href="{{ path('live') }}">
            <i class="fas fa-satellite-dish mr-2.5 text-xs"></i> {% trans %}realtime{% endtrans %}
        </a>
        
        <!-- Mobile Wiki Accordion -->
        <div class="space-y-1">
            <button id="mobile-wiki-toggle" class="w-full flex items-center justify-between px-4 py-3 rounded-xl text-sm font-semibold transition-all border border-transparent text-slate-650 hover:bg-slate-100/50 dark:text-gray-300 dark:hover:bg-gray-900/45 cursor-pointer {% if route_name in ['spacestation', 'agency', 'astronaut', 'launch'] %} bg-white dark:bg-gray-900 text-indigo-600 dark:text-indigo-400 shadow-sm border border-slate-200 dark:border-gray-800 {% endif %}">
                <span class="flex items-center">
                    <i class="fas fa-book-open mr-2.5 text-xs"></i> {{ 'spaceWiki'|trans }}
                </span>
                <i id="mobile-wiki-chevron" class="fas fa-chevron-down text-xs transition-transform duration-200"></i>
            </button>
            <div id="mobile-wiki-menu" class="hidden pl-6 pr-4 py-2 space-y-4 border-l border-slate-200 dark:border-gray-800 ml-4 mt-1">
                <!-- Space Stations -->
                <div>
                    <h5 class="text-[10px] font-bold text-slate-400 dark:text-gray-500 uppercase tracking-wider mb-1.5 flex items-center">
                        <i class="fas fa-satellite mr-1.5"></i> Space Stations
                    </h5>
                    <div class="space-y-1 pl-2">
                        {% for station in get_wiki_spacestations() %}
                            <a href="{{ path('spacestation', {'idApi': station.idApi}) }}" class="block py-1 text-xs font-semibold text-slate-700 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400">
                                {{ station.name }}
                            </a>
                        {% endfor %}
                    </div>
                </div>
                <!-- Space Agencies -->
                <div>
                    <h5 class="text-[10px] font-bold text-slate-400 dark:text-gray-500 uppercase tracking-wider mb-1.5 flex items-center">
                        <i class="fas fa-building mr-1.5"></i> Space Agencies
                    </h5>
                    <div class="space-y-1 pl-2 max-h-32 overflow-y-auto">
                        {% for agency in get_wiki_agencies() %}
                            <a href="{{ path('agency', {'nameSlug': agency.name | slug | lower, 'idApi': agency.idApi}) }}" class="block py-1 text-xs font-semibold text-slate-700 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400">
                                {{ agency.name }}
                            </a>
                        {% endfor %}
                    </div>
                </div>
                <!-- Active Astronauts -->
                <div>
                    <h5 class="text-[10px] font-bold text-slate-400 dark:text-gray-500 uppercase tracking-wider mb-1.5 flex items-center">
                        <i class="fas fa-user-astronaut mr-1.5"></i> Active Astronauts
                    </h5>
                    <div class="space-y-1 pl-2 max-h-32 overflow-y-auto">
                        {% for astronaut in get_wiki_astronauts() %}
                            <a href="{{ path('astronaut', {'nameAstro': astronaut.name | slug | lower, 'idApi': astronaut.idApi}) }}" class="block py-1 text-xs font-semibold text-slate-700 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400">
                                {{ astronaut.name }}
                            </a>
                        {% endfor %}
                    </div>
                </div>
                <!-- Recent Launches -->
                <div>
                    <h5 class="text-[10px] font-bold text-slate-400 dark:text-gray-500 uppercase tracking-wider mb-1.5 flex items-center">
                        <i class="fas fa-rocket mr-1.5"></i> Recent Launches
                    </h5>
                    <div class="space-y-1 pl-2 max-h-32 overflow-y-auto">
                        {% for launch in get_wiki_launches() %}
                            <a href="{{ path('launch', {'slug': launch.slug, 'idApi': launch.idApi}) }}" class="block py-1 text-xs font-semibold text-slate-700 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400 truncate">
                                {{ launch.name }}
                            </a>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>

{% if route_name == "home" %}
<!-- Hero branding section -->
<div class="text-center py-16 sm:py-20 px-4 max-w-4xl mx-auto space-y-6">
    <h1 class="text-4xl sm:text-6xl font-black tracking-tight text-slate-900 dark:text-white leading-tight sm:leading-tight">
        {{ 'heroTitle'|trans|raw }}
    </h1>
    <p class="text-base sm:text-xl text-slate-600 dark:text-gray-300 font-medium max-w-2xl mx-auto leading-relaxed">
        {{ 'heroSubtitle'|trans }}
    </p>
    
    <!-- Search card -->
    <div class="max-w-md mx-auto mt-8 bg-white/80 dark:bg-gray-900/60 backdrop-blur-md border border-slate-250 dark:border-gray-800/80 rounded-2xl p-6 shadow-xl text-slate-800 dark:text-gray-100 text-left">
        <h2 class="text-xl font-bold tracking-tight text-slate-900 dark:text-white mb-4">
            {% trans %}passesText{% endtrans %}
        </h2>
        
        <form action="{{ path('home') }}" method="POST" id="formLocation" class="space-y-4">
            <div class="relative">
                <input id="location" 
                       class="w-full bg-slate-50 dark:bg-gray-950/60 border border-slate-250 dark:border-gray-850 rounded-xl px-4 py-3 text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all text-sm" 
                       type="text" 
                       placeholder="{% if info.city %}{{ info.city }}{% else %}{% trans %}city{% endtrans %}{% endif %}" 
                       value=""/>
                <button type="button" 
                        id="localisation" 
                        class="absolute right-2 top-2 bg-slate-200 hover:bg-slate-300 dark:bg-gray-800 dark:hover:bg-gray-700 border border-slate-300 dark:border-gray-750 text-indigo-650 dark:text-indigo-400 rounded-lg px-3 py-1.5 text-xs font-medium transition-all flex items-center space-x-1"
                        title="Use current location">
                    <i class="fas fa-map-marker-alt"></i>
                    <span class="hidden sm:inline">GPS</span>
                </button>
            </div>
            
            <input type="hidden" id="name" name="city"/>
            <input type="hidden" id="lat" name="lat"/>
            <input type="hidden" id="lon" name="lon"/>
            
            <button id="buttonSubmit" 
                    type="submit" 
                    class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold py-3 px-4 rounded-xl shadow-md transition-all text-sm">
                {% trans %}send{% endtrans %}
            </button>
        </form>
    </div>
</div>
{% endif %}

<script>
    // Pure Vanilla JS for Mobile Toggle
    document.addEventListener('DOMContentLoaded', () => {
        const toggle = document.getElementById('mobile-menu-toggle');
        const menu = document.getElementById('mobile-menu');
        
        if (toggle && menu) {
            toggle.addEventListener('click', () => {
                menu.classList.toggle('hidden');
                const icon = toggle.querySelector('i');
                if (icon.classList.contains('fa-bars')) {
                    icon.classList.remove('fa-bars');
                    icon.classList.add('fa-times');
                } else {
                    icon.classList.remove('fa-times');
                    icon.classList.add('fa-bars');
                }
            });
        }

        // Mobile Wiki Accordion Toggle
        const mobileWikiToggle = document.getElementById('mobile-wiki-toggle');
        const mobileWikiMenu = document.getElementById('mobile-wiki-menu');
        const mobileWikiChevron = document.getElementById('mobile-wiki-chevron');
        if (mobileWikiToggle && mobileWikiMenu) {
            mobileWikiToggle.addEventListener('click', () => {
                mobileWikiMenu.classList.toggle('hidden');
                if (mobileWikiChevron) {
                    mobileWikiChevron.classList.toggle('rotate-180');
                }
            });
        }

        // Page Share Button Controller
        const pageShareBtn = document.getElementById('page-share-btn');
        if (pageShareBtn) {
            pageShareBtn.addEventListener('click', async () => {
                const shareData = {
                    title: document.title,
                    text: document.querySelector('meta[name="description"]')?.content || document.title,
                    url: window.location.href
                };

                if (navigator.share) {
                    try {
                        await navigator.share(shareData);
                    } catch (err) {
                        // User cancelled or share failed silently
                    }
                } else {
                    // Desktop fallback: copy link to clipboard
                    try {
                        await navigator.clipboard.writeText(window.location.href);
                        if (window.showToast) {
                            window.showToast('Page link copied to clipboard!');
                        }
                    } catch (err) {
                        // Fallback for older browsers
                        const textArea = document.createElement('textarea');
                        textArea.value = window.location.href;
                        textArea.style.position = 'fixed';
                        textArea.style.opacity = '0';
                        document.body.appendChild(textArea);
                        textArea.select();
                        document.execCommand('copy');
                        textArea.remove();
                        if (window.showToast) {
                            window.showToast('Page link copied to clipboard!');
                        }
                    }
                }
            });
        }
    });
</script>