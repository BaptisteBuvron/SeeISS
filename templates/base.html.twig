<!DOCTYPE html>
<html lang="{% trans %}lang{% endtrans %}" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="title" content="SeeISS">
    <meta name="description"
          content="The International Space Station is regularly visible to the naked eye. Get all the passes of the International Space Station from your location.">
    <meta name="keywords"
          content="iss, spot, track, International Space Station, station spatiale internationale, nasa, see, space, sky, station, naked eyes">
    <meta name="robots" content="index, follow">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="language" content="{% trans %}language{% endtrans %}">
    <meta name="author" content="Baptiste BUVRON">
    <link rel="shortcut icon" href="{{ asset('images/international-space-station-icon.ico') }}">
    <title>{% block title %}SeeISS{% endblock %}</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    {% block javascriptsHead %}
        <!-- Global site tag (gtag.js) - Google Analytics -->
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-D4JYXK25GT"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());

            gtag('config', 'G-D4JYXK25GT');
        </script>

        <script src="https://kit.fontawesome.com/67913222db.js" crossorigin="anonymous"></script>
        <script type='text/javascript'
                src='https://platform-api.sharethis.com/js/sharethis.js#property=5fa8393f63b0cd00123cba5c&product=inline-share-buttons'
                async='async'></script>
        <script src="https://unpkg.com/leaflet@1.7.1/dist/leaflet.js"
                integrity="sha512-XQoYMqMTK8LvdxXYG3nZ448hOEQiglfqkJs1NOQV44cWnUrBc8PkAOcXy20w0vlaXaVUearIOBhiXZ5V3ynxwA=="
                crossorigin=""></script>
        <script src="https://unpkg.com/@joergdietrich/leaflet.terminator"></script>
    {% endblock %}
    
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.7.1/dist/leaflet.css"
              integrity="sha512-xodZBNTC5n17Xt2atTPuE1HxjVMSvLVW9ocqUKLsCC5CXdbqCmblAshOMAS6/keqq/sMZMZ19scR4PsZChSR7A=="
              crossorigin=""/>
    {% endblock %}

    {{ encore_entry_script_tags('app') }}
    
    <!-- Early theme detector to prevent FOUC -->
    <script>
        if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
</head>

<body class="flex flex-col min-h-screen font-sans antialiased transition-colors duration-300">
    {% include 'partials/header.html.twig' %}
    
    <main class="flex-grow">
        {% block body %}{% endblock %}
    </main>

    {% include 'partials/footer.html.twig' %}

    {% block javascripts %}
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                // Theme Toggle Controller (Sliding Switch)
                const themeToggleBtn = document.getElementById('theme-toggle');

                if (themeToggleBtn) {
                    // Set initial aria-checked state
                    const isDarkInitial = document.documentElement.classList.contains('dark');
                    themeToggleBtn.setAttribute('aria-checked', isDarkInitial ? 'true' : 'false');

                    themeToggleBtn.addEventListener('click', () => {
                        const isDark = document.documentElement.classList.contains('dark');
                        if (isDark) {
                            document.documentElement.classList.remove('dark');
                            localStorage.setItem('color-theme', 'light');
                            themeToggleBtn.setAttribute('aria-checked', 'false');
                        } else {
                            document.documentElement.classList.add('dark');
                            localStorage.setItem('color-theme', 'dark');
                            themeToggleBtn.setAttribute('aria-checked', 'true');
                        }
                    });
                }

                // Click-based Language Selector Controller
                const langBtn = document.getElementById('language-selector-btn');
                const langDropdown = document.getElementById('language-selector-dropdown');

                if (langBtn && langDropdown) {
                    langBtn.addEventListener('click', (e) => {
                        e.stopPropagation();
                        langDropdown.classList.toggle('opacity-0');
                        langDropdown.classList.toggle('pointer-events-none');
                    });

                    document.addEventListener('click', (e) => {
                        if (!langBtn.contains(e.target) && !langDropdown.contains(e.target)) {
                            langDropdown.classList.add('opacity-0', 'pointer-events-none');
                        }
                    });
                }

                // --- Floating Selection Share Popover ---
                let sharePopover = null;
                let selectedText = '';
                let popoverVisible = false;

                function createSharePopover() {
                    const el = document.createElement('div');
                    el.id = 'text-share-popover';
                    el.style.cssText = 'position:fixed;z-index:9999;opacity:0;pointer-events:none;transform:translateY(-6px);transition:opacity .18s ease,transform .18s ease;';
                    el.innerHTML = `
                        <div style="display:flex;align-items:center;gap:2px;background:rgba(15,23,42,0.96);backdrop-filter:blur(12px);border:1px solid rgba(100,116,139,0.3);border-radius:14px;padding:4px 6px;box-shadow:0 8px 32px rgba(0,0,0,0.4);">
                            <button data-share="x" style="all:unset;cursor:pointer;padding:7px 8px;border-radius:8px;color:#94a3b8;display:flex;align-items:center;" title="X (Twitter)"
                                    onmouseover="this.style.background='rgba(255,255,255,0.1)';this.style.color='#fff'" onmouseout="this.style.background='';this.style.color='#94a3b8'">
                                <i class="fab fa-twitter" style="font-size:14px"></i>
                            </button>
                            <button data-share="whatsapp" style="all:unset;cursor:pointer;padding:7px 8px;border-radius:8px;color:#94a3b8;display:flex;align-items:center;" title="WhatsApp"
                                    onmouseover="this.style.background='rgba(255,255,255,0.1)';this.style.color='#25D366'" onmouseout="this.style.background='';this.style.color='#94a3b8'">
                                <i class="fab fa-whatsapp" style="font-size:15px"></i>
                            </button>
                            <button data-share="facebook" style="all:unset;cursor:pointer;padding:7px 8px;border-radius:8px;color:#94a3b8;display:flex;align-items:center;" title="Facebook"
                                    onmouseover="this.style.background='rgba(255,255,255,0.1)';this.style.color='#1877F2'" onmouseout="this.style.background='';this.style.color='#94a3b8'">
                                <i class="fab fa-facebook-f" style="font-size:14px"></i>
                            </button>
                            <div style="width:1px;height:18px;background:rgba(100,116,139,0.35);margin:0 2px;"></div>
                            <button data-share="copy" style="all:unset;cursor:pointer;padding:7px 8px;border-radius:8px;color:#94a3b8;display:flex;align-items:center;" title="Copy link"
                                    onmouseover="this.style.background='rgba(255,255,255,0.1)';this.style.color='#818cf8'" onmouseout="this.style.background='';this.style.color='#94a3b8'">
                                <i class="fas fa-link" style="font-size:12px"></i>
                            </button>
                            ${navigator.share ? `
                            <button data-share="native" style="all:unset;cursor:pointer;padding:7px 8px;border-radius:8px;color:#94a3b8;display:flex;align-items:center;" title="Share..."
                                    onmouseover="this.style.background='rgba(255,255,255,0.1)';this.style.color='#fff'" onmouseout="this.style.background='';this.style.color='#94a3b8'">
                                <i class="fas fa-share-alt" style="font-size:12px"></i>
                            </button>` : ''}
                        </div>
                    `;
                    document.body.appendChild(el);
                    sharePopover = el;

                    // Handle clicks inside the popover
                    el.addEventListener('mousedown', (e) => e.preventDefault()); // Prevent selection loss
                    el.addEventListener('click', (e) => {
                        const btn = e.target.closest('[data-share]');
                        if (!btn) return;
                        e.preventDefault();
                        e.stopPropagation();
                        
                        const action = btn.dataset.share;
                        const shareUrl = buildFragmentUrl();
                        const quote = selectedText.length > 200 ? selectedText.substring(0, 200) + '…' : selectedText;

                        switch (action) {
                            case 'x':
                                window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent('"' + quote + '" ' + shareUrl)}`, '_blank', 'noopener');
                                break;
                            case 'whatsapp':
                                window.open(`https://api.whatsapp.com/send?text=${encodeURIComponent('"' + quote + '"\n\n' + shareUrl)}`, '_blank', 'noopener');
                                break;
                            case 'facebook':
                                window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}&quote=${encodeURIComponent(quote)}`, '_blank', 'noopener');
                                break;
                            case 'copy':
                                navigator.clipboard.writeText(shareUrl).then(() => {
                                    showToast('Link copied!');
                                }).catch(() => {
                                    // Fallback
                                    const ta = document.createElement('textarea');
                                    ta.value = shareUrl;
                                    ta.style.cssText = 'position:fixed;opacity:0';
                                    document.body.appendChild(ta);
                                    ta.select();
                                    document.execCommand('copy');
                                    ta.remove();
                                    showToast('Link copied!');
                                });
                                break;
                            case 'native':
                                navigator.share({ title: document.title, text: selectedText, url: shareUrl }).catch(() => {});
                                break;
                        }
                        hideSharePopover();
                    });
                }

                function buildFragmentUrl() {
                    const base = window.location.origin + window.location.pathname;
                    const clean = selectedText.replace(/[\n\r]+/g, ' ').trim();
                    const words = clean.split(/\s+/);
                    if (words.length > 6) {
                        const prefix = words.slice(0, 3).join(' ');
                        const suffix = words.slice(-3).join(' ');
                        return `${base}#:~:text=${encodeURIComponent(prefix)},${encodeURIComponent(suffix)}`;
                    }
                    return `${base}#:~:text=${encodeURIComponent(clean)}`;
                }

                function showSharePopover(rect) {
                    if (!sharePopover) createSharePopover();

                    // Use viewport coordinates directly (position:fixed)
                    const popW = sharePopover.offsetWidth || 220;
                    const popH = sharePopover.offsetHeight || 44;

                    let top = rect.top - popH - 10;
                    let left = rect.left + (rect.width / 2) - (popW / 2);

                    // If not enough space above, show below
                    if (top < 8) top = rect.bottom + 10;
                    // Clamp horizontally
                    left = Math.max(8, Math.min(window.innerWidth - popW - 8, left));

                    sharePopover.style.top = top + 'px';
                    sharePopover.style.left = left + 'px';
                    sharePopover.style.opacity = '1';
                    sharePopover.style.pointerEvents = 'auto';
                    sharePopover.style.transform = 'translateY(0)';
                    popoverVisible = true;
                }

                function hideSharePopover() {
                    if (sharePopover && popoverVisible) {
                        sharePopover.style.opacity = '0';
                        sharePopover.style.pointerEvents = 'none';
                        sharePopover.style.transform = 'translateY(-6px)';
                        popoverVisible = false;
                    }
                }

                function checkSelection() {
                    const sel = window.getSelection();
                    if (!sel || sel.isCollapsed) { hideSharePopover(); return; }
                    
                    const text = sel.toString().trim();
                    if (text.length < 3) { hideSharePopover(); return; }

                    const range = sel.getRangeAt(0);
                    let container = range.commonAncestorContainer;
                    if (container.nodeType === Node.TEXT_NODE) {
                        container = container.parentNode;
                    }
                    if (!container || !container.closest || !container.closest('.wiki-passage-container')) {
                        hideSharePopover();
                        return;
                    }

                    selectedText = text;
                    const rect = range.getBoundingClientRect();
                    if (rect.width > 0) {
                        showSharePopover(rect);
                    }
                }

                // Mouse: show on mouseup after selection
                document.addEventListener('mouseup', (e) => {
                    if (sharePopover && sharePopover.contains(e.target)) return;
                    setTimeout(checkSelection, 20);
                });

                // Touch: show after touch selection changes  
                document.addEventListener('selectionchange', () => {
                    // Only useful on mobile where selectionchange fires for touch selection
                    if ('ontouchstart' in window) {
                        setTimeout(checkSelection, 100);
                    }
                });

                // Hide on mousedown outside popover (new selection starting)
                document.addEventListener('mousedown', (e) => {
                    if (sharePopover && !sharePopover.contains(e.target)) {
                        hideSharePopover();
                    }
                });

                // Hide on scroll
                let scrollTimer;
                window.addEventListener('scroll', () => {
                    if (popoverVisible) {
                        clearTimeout(scrollTimer);
                        scrollTimer = setTimeout(() => {
                            const sel = window.getSelection();
                            if (sel && !sel.isCollapsed && sel.toString().trim().length >= 3) {
                                const rect = sel.getRangeAt(0).getBoundingClientRect();
                                if (rect.width > 0) showSharePopover(rect);
                            } else {
                                hideSharePopover();
                            }
                        }, 100);
                    }
                }, { passive: true });

                function showToast(message) {
                    const toast = document.createElement('div');
                    toast.className = 'fixed bottom-5 right-5 z-50 bg-slate-900 dark:bg-indigo-950 text-white px-4 py-2.5 rounded-xl shadow-lg border border-slate-700/50 dark:border-indigo-500/30 text-xs font-semibold flex items-center gap-2 transform translate-y-10 opacity-0 transition-all duration-300';
                    toast.innerHTML = `<i class="fas fa-check-circle text-emerald-400"></i> <span>${message}</span>`;
                    document.body.appendChild(toast);
                    
                    setTimeout(() => {
                        toast.classList.remove('translate-y-10', 'opacity-0');
                    }, 10);
                    
                    setTimeout(() => {
                        toast.classList.add('translate-y-10', 'opacity-0');
                        setTimeout(() => toast.remove(), 300);
                    }, 3000);
                }
                window.showToast = showToast;
            });
        </script>
    {% endblock %}
</body>
</html>
