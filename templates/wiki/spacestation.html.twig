{% extends 'base.html.twig' %}
{% block title %}SeeISS - Space Station: {{ spaceStation.name }}{% endblock %}

{% block body %}
<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 text-slate-800 dark:text-gray-200 wiki-passage-container">
    <!-- Page Header (Airy & Unboxed) -->
    <div class="space-y-4 mb-8">
        <span class="inline-flex items-center text-xs font-bold text-indigo-600 dark:text-indigo-400 uppercase tracking-widest">
            <i class="fas fa-satellite mr-1.5"></i>{{ spaceStation.type }}
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 dark:text-white tracking-tight">
            {{ spaceStation.name }}
        </h1>
        <p class="text-slate-500 dark:text-gray-400 text-sm sm:text-base max-w-2xl leading-relaxed">
            Discover the technical specifications, active crew, and docked cargo or crew spacecraft currently in orbit.
        </p>
    </div>

    <!-- Main Hero Image (Clean, rounded, no container) -->
    <div class="aspect-[21/9] w-full rounded-2xl overflow-hidden bg-slate-950 border border-slate-200/60 dark:border-gray-800/80 mb-12 shadow-sm">
        <img src="{{ spaceStation.imageUrl }}" 
             alt="{{ spaceStation.name }}" 
             class="w-full h-full object-cover">
    </div>

    <!-- Content Columns -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        
        <!-- Left: Description and Docked Vehicles (Editorial Flow) -->
        <div class="lg:col-span-8 space-y-12">
            <!-- Mission Description -->
            <div class="space-y-4 wiki-passage-container">
                <h2 class="text-xl font-bold tracking-tight text-slate-900 dark:text-white uppercase tracking-wider text-xs text-slate-400 dark:text-gray-500">
                    Mission Description
                </h2>
                <div class="text-slate-700 dark:text-gray-300 leading-relaxed text-base sm:text-lg text-justify whitespace-pre-line font-medium">
                    {{ spaceStation.description | translate_db(app.request.locale) }}
                </div>
            </div>

            <!-- Docked Vehicles List -->
            <div class="space-y-6">
                <h2 class="text-xl font-bold tracking-tight text-slate-900 dark:text-white uppercase tracking-wider text-xs text-slate-400 dark:text-gray-500">
                    Docked Vehicles
                </h2>
                <div class="divide-y divide-slate-150 dark:divide-gray-850">
                    {% for docking in spaceStation.dockingLocation %}
                        <div class="py-6 first:pt-0 last:pb-0 flex flex-col sm:flex-row gap-6 items-start justify-between group">
                            <div class="flex gap-4 items-start">
                                <!-- Minimal thumbnail -->
                                <div class="w-16 h-16 rounded-xl overflow-hidden bg-slate-100 dark:bg-gray-900 border border-slate-200/60 dark:border-gray-800 flex-shrink-0">
                                    <img src="{{ docking.spaceCraft.spaceCraftConfig.imageUrl }}" 
                                         alt="" 
                                         class="w-full h-full object-cover">
                                </div>
                                <div class="space-y-1">
                                    <h4 class="text-base font-bold text-slate-900 dark:text-white group-hover:text-indigo-650 dark:group-hover:text-indigo-400 transition-colors">
                                        {{ docking.spaceCraft.name }}
                                    </h4>
                                    <!-- Agency link -->
                                    <div class="flex flex-wrap items-center gap-2 text-xs text-slate-500 dark:text-gray-400">
                                        <a href="{{ path('agency', {'nameSlug' : docking.spaceCraft.spaceCraftConfig.agency.name | slug | lower, 'idApi' : docking.spaceCraft.spaceCraftConfig.agency.idApi }) }}"
                                           class="text-indigo-600 dark:text-indigo-400 hover:underline font-semibold">
                                            {{ docking.spaceCraft.spaceCraftConfig.agency.name }}
                                        </a>
                                        <span>&bull;</span>
                                        <span>Port: <strong class="text-slate-700 dark:text-gray-300 font-medium">{{ docking.name }}</strong></span>
                                        <span>&bull;</span>
                                        <span id="{{ docking.idApi }}-docking"></span>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Action button Link -->
                            <a href="{{ path('launch', {'slug' : docking.spaceCraft.launch.slug, 'idApi': docking.spaceCraft.launch.idApi}) }}"
                               class="inline-flex items-center text-xs font-bold text-slate-600 hover:text-slate-900 dark:text-gray-400 dark:hover:text-white transition-colors bg-slate-100 hover:bg-slate-200 dark:bg-gray-900 dark:hover:bg-gray-800/80 border border-slate-200 dark:border-gray-800 px-3.5 py-2 rounded-xl">
                                <span>Launch Info</span>
                                <i class="fas fa-arrow-right text-[10px] ml-1.5 opacity-70"></i>
                            </a>
                        </div>
                        
                        <script>
                            document.getElementById("{{ docking.idApi }}-docking").innerText = "Docked: " + new Date("{{ docking.docking | date('c') }}").toLocaleDateString();
                        </script>
                    {% else %}
                        <p class="text-sm text-slate-500 dark:text-gray-500 py-4">No vehicles are currently docked.</p>
                    {% endfor %}
                </div>
            </div>
        </div>

        <!-- Right: Technical specs, Partners & Crew (Clean Minimalist Lists) -->
        <div class="lg:col-span-4 space-y-10 lg:sticky lg:top-20">
            <!-- Technical Metrics -->
            <div class="space-y-4">
                <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-gray-500">
                    Specifications
                </h3>
                <div class="divide-y divide-slate-100 dark:divide-gray-850 text-sm">
                    <div class="flex justify-between py-3">
                        <span class="text-slate-500 dark:text-gray-400">Orbit</span>
                        <span class="font-bold text-slate-800 dark:text-white">{{ spaceStation.orbit }}</span>
                    </div>
                    <div class="flex justify-between py-3">
                        <span class="text-slate-500 dark:text-gray-400">Mass</span>
                        <span class="font-bold text-slate-800 dark:text-white font-mono">{{ spaceStation.mass }} Tons</span>
                    </div>
                    <div class="flex justify-between py-3">
                        <span class="text-slate-500 dark:text-gray-400">Dimensions</span>
                        <span class="font-bold text-slate-800 dark:text-white font-mono">{{ spaceStation.height }}m &times; {{ spaceStation.width }}m</span>
                    </div>
                    <div class="flex justify-between py-3">
                        <span class="text-slate-500 dark:text-gray-400">Volume</span>
                        <span class="font-bold text-slate-800 dark:text-white font-mono">{{ spaceStation.volume }} m&sup3;</span>
                    </div>
                    <div class="flex justify-between py-3">
                        <span class="text-slate-500 dark:text-gray-400">Onboard Crew</span>
                        <span class="font-bold text-slate-800 dark:text-white font-mono">{{ spaceStation.onboardCrew }} / 7</span>
                    </div>
                    <div class="flex justify-between py-3">
                        <span class="text-slate-500 dark:text-gray-400">Founded</span>
                        <span class="font-bold text-slate-800 dark:text-white font-mono">{{ spaceStation.founded | date('Y-m-d') }}</span>
                    </div>
                </div>
            </div>

            <!-- Partners -->
            <div class="space-y-4">
                <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-gray-500">
                    Partners
                </h3>
                <div class="flex flex-wrap gap-2">
                    {% for owner in spaceStation.owners %}
                        <a href="{{ path('agency', {'nameSlug' : owner.name | slug | lower, 'idApi' : owner.idApi }) }}"
                           class="inline-flex items-center space-x-1.5 bg-slate-50 hover:bg-slate-100 dark:bg-gray-900 dark:hover:bg-gray-800/80 border border-slate-200 dark:border-gray-800 px-3 py-1.5 rounded-xl transition-all text-xs font-semibold text-slate-700 dark:text-gray-300">
                            {% if owner.logoUrl %}
                                <img src="{{ owner.logoUrl }}" alt="" class="w-3.5 h-3.5 object-contain filter dark:brightness-110">
                            {% endif %}
                            <span>{{ owner.name }}</span>
                        </a>
                    {% endfor %}
                </div>
            </div>

            <!-- Crew Directory (Circular Minimalist Lists) -->
            <div class="space-y-4">
                <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-gray-500">
                    Active Crew
                </h3>
                <div class="space-y-4 max-h-[350px] overflow-y-auto pr-1">
                    {% for astronaut in spaceStation.crew %}
                        <a href="{{ path('astronaut', {'nameAstro' : astronaut.name | slug | lower ,'idApi': astronaut.idApi}) }}" 
                           class="flex items-center space-x-3 group text-slate-800 dark:text-gray-250 hover:text-indigo-650 dark:hover:text-indigo-400 transition-colors">
                            <div class="w-10 h-10 rounded-full overflow-hidden border border-slate-200 dark:border-gray-800 bg-slate-100 dark:bg-gray-950 flex-shrink-0">
                                <img src="{{ astronaut.profileImg }}" alt="" class="w-full h-full object-cover">
                            </div>
                            <div>
                                <span class="font-bold text-sm block group-hover:underline text-slate-900 dark:text-white leading-tight">{{ astronaut.name }}</span>
                                <span class="text-[10px] text-slate-500 dark:text-gray-400 uppercase font-semibold tracking-wider block mt-0.5">{{ astronaut.role ?: 'Crew Member' }}</span>
                            </div>
                        </a>
                    {% else %}
                        <p class="text-xs text-slate-500 dark:text-gray-500">No astronauts currently onboard.</p>
                    {% endfor %}
                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}